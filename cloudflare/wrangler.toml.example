name = "aeroview-workflow-dispatcher"
main = "aeroview-workflow-dispatcher.js"
compatibility_date = "2026-05-26"

[triggers]
# Paused until the feed uses a schedule source that includes aircraft registrations.
# Enable this after the data source is fixed:
# crons = ["0 0 * * *"]

[vars]
GITHUB_OWNER = "kuanyangdai-droid"
GITHUB_REPO = "aeroview-live-feed"
GITHUB_WORKFLOW = "update-feed.yml"
GITHUB_REF = "main"
